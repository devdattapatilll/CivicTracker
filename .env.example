# ──────────────────────────────────────────────────────────
# CivicTrack — Environment Configuration Template
# ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local to Git.

# ML Backend Service URL (Render)
ML_SERVICE_URL=https://civictrack-ml.onrender.com

# Firebase Configuration
# These values are configured directly in index.html.
# Update them in the firebaseConfig object if using a different project.
# FIREBASE_API_KEY=your_api_key
# FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# FIREBASE_PROJECT_ID=your_project_id
# FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
# FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# FIREBASE_APP_ID=your_app_id

# Vercel Deployment (set as GitHub Secrets for CI/CD)
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_PROJECT_ID=your_project_id

# Roboflow API Key (for dataset downloads during training)
# ROBOFLOW_API_KEY=your_free_api_key
